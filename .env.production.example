# ==========================================
# English Fairy - Production Environment
# ==========================================

# ── App ──
APP_NAME=english-fairy-api
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=CHANGE_ME_RANDOM_64CHAR_STRING
APP_CORS_ORIGINS=["https://your-domain.com"]

# ── Database ──
DB_HOST=db
DB_PORT=5432
DB_USER=english_fairy
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=english_fairy
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── JWT ──
JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET_64CHAR
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Parent PIN ──
PARENT_PIN_HASH_ROUNDS=12

# ── LLM Tier 1 (Ollama on host network) ──
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=exaone3.5:7.8b

# ── LLM Tier 2 ──
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.0-flash

# ── LLM Tier 3 ──
GEMINI_PRO_MODEL=gemini-2.5-pro
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Speech ──
WHISPER_API_KEY=
WHISPER_MODEL=whisper-1
GOOGLE_TTS_API_KEY=
GOOGLE_TTS_VOICE=en-US-Neural2-F
GOOGLE_TTS_SPEAKING_RATE=0.85

# ── Storage ──
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS
S3_SECRET_KEY=CHANGE_ME_MINIO_SECRET
S3_BUCKET_AUDIO=english-fairy-audio
S3_BUCKET_IMAGES=english-fairy-images
S3_REGION=us-east-1

# ── Frontend ──
NEXT_PUBLIC_API_URL=https://your-domain.com/api/v1
NEXT_PUBLIC_WS_URL=wss://your-domain.com/api/v1
NEXT_PUBLIC_APP_NAME=영어요정
NEXT_PUBLIC_APP_URL=https://your-domain.com

# ── HAProxy ──
HAPROXY_HTTP_PORT=80
HAPROXY_HTTPS_PORT=443
HAPROXY_STATS_PORT=8404

# ── Cloudflare Tunnel ──
CLOUDFLARE_TUNNEL_TOKEN=YOUR_TUNNEL_TOKEN
