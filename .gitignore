# ═══════════════════════════════════════════════════════════
# English Learning Platform - .gitignore
# ═══════════════════════════════════════════════════════════

# ──── Environment Variables & Secrets ────
.env
.env.local
.env.development
.env.production
.env.test
*.env
.env.*

# ──── Backend (Python/FastAPI) ────
# Virtual environments
backend/.venv/
backend/venv/
backend/env/
backend/ENV/
.venv/
venv/
*.pyc
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# FastAPI/Uvicorn
backend/instance/
backend/.pytest_cache/
backend/.coverage
backend/htmlcov/
backend/.tox/
backend/.hypothesis/

# Alembic
backend/alembic/versions/*.pyc

# ──── Frontend (Next.js/React) ────
# Dependencies
frontend/node_modules/
node_modules/
frontend/.pnp
frontend/.pnp.js

# Production builds
frontend/.next/
frontend/out/
frontend/build/
frontend/dist/

# Next.js cache
frontend/.next/
frontend/.swc/

# TypeScript
frontend/*.tsbuildinfo
frontend/next-env.d.ts

# PWA
frontend/public/sw.js
frontend/public/workbox-*.js
frontend/public/sw.js.map
frontend/public/workbox-*.js.map

# ──── Database & Docker ────
# PostgreSQL
*.sql
*.db
*.sqlite
*.sqlite3
postgres-data/
pgdata/

# Docker volumes
docker-data/

# ──── Logs ────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# ──── OS & IDE ────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
[Dd]esktop.ini
$RECYCLE.BIN/

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# JetBrains IDEs
.idea/
*.iml
*.ipr
*.iws

# Vim
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]

# ──── Testing ────
.coverage
htmlcov/
.pytest_cache/
coverage/
*.cover

# ──── Temporary Files ────
tmp/
temp/
*.tmp
*.bak
*.swp
*~.nib

# ──── SSL Certificates ────
*.pem
*.key
*.crt
*.p12
certs/
ssl/

# ──── Binary & Executables ────
*.exe
*.dll
*.so
*.dylib
mkcert-*

# ──── Claude Code ────
.claude/

# ──── Stitch (Legacy) ────
stitch_english_fairy_login/

# ──── Compressed Archives ────
*.tar.gz
*.zip
*.7z
*.rar

# ──── Systemd Service Files (Keep in repo for deployment) ────
# These are intentionally NOT ignored
# english-fairy-backend.service
# english-fairy-frontend.service

# ──── Keep Example Files ────
!.env.example
!.env.local.example
!.env.production.example
