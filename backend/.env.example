# ======================
# App
# ======================
APP_NAME=english-fairy-api
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-me-to-random-secret
APP_CORS_ORIGINS=["http://localhost:3000"]

# ======================
# Database
# ======================
DB_HOST=localhost
DB_PORT=5432
DB_USER=english_fairy
DB_PASSWORD=change-me
DB_NAME=english_fairy
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ======================
# Redis
# ======================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ======================
# JWT
# ======================
JWT_SECRET_KEY=change-me-to-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ======================
# Parent PIN
# ======================
PARENT_PIN_HASH_ROUNDS=12

# ======================
# LLM Tier 1 (Local)
# ======================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=exaone3.5:7.8b

# ======================
# LLM Tier 2 (Mid)
# ======================
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ======================
# LLM Tier 3 (High)
# ======================
GEMINI_PRO_MODEL=gemini-2.5-pro
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ======================
# Speech
# ======================
WHISPER_API_KEY=
WHISPER_MODEL=whisper-1
GOOGLE_TTS_API_KEY=
GOOGLE_TTS_VOICE=en-US-Neural2-F
GOOGLE_TTS_SPEAKING_RATE=0.85

# ======================
# Storage (S3 compatible)
# ======================
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_AUDIO=english-fairy-audio
S3_BUCKET_IMAGES=english-fairy-images
S3_REGION=us-east-1
